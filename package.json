{
  "name": "object0",
  "private": true,
  "version": "1.2.0",
  "description": "FOSS desktop S3 bucket manager built with Tauri",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:app": "bun run tauri dev",
    "build": "tsc && vite build",
    "build:app": "bun run tauri build",
    "preview": "vite preview",
    "check": "biome check .",
    "check:all": "bun run check && bun run build && cd src-tauri && cargo check",
    "lint": "biome lint .",
    "format": "biome format --write .",
    "release:sync-version": "node ./scripts/release/sync-version.mjs",
    "updater:manifest": "bun ./scripts/updater/build-static-manifest.mjs",
    "updater:verify": "bun ./scripts/updater/verify-static-manifest.mjs",
    "tauri": "tauri"
  },
  "dependencies": {
    "@base-ui/react": "^1.6.0",
    "@fontsource-variable/geist": "^5.2.9",
    "@tanstack/react-virtual": "^3.14.3",
    "@tauri-apps/api": "^2.11.1",
    "@tauri-apps/plugin-opener": "^2.5.4",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "framer-motion": "^12.40.0",
    "lucide-react": "^1.21.0",
    "next-themes": "^0.4.6",
    "qrcode.react": "^4.2.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.0",
    "@tailwindcss/vite": "^4.3.1",
    "@tauri-apps/cli": "^2.11.3",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.2.0",
    "shadcn": "^4.11.0",
    "tailwindcss": "^4.3.1",
    "typescript": "~5.9.3",
    "vite": "^7.3.5"
  }
}
